{
  "name": "@resonatehq/gcp",
  "version": "0.2.0",
  "description": "Resonate FaaS handler for Google Cloud Functions (TypeScript)",
  "repository": {
    "url": "https://github.com/resonatehq/resonate-faas-gcp-ts"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "resonate",
    "durable-execution",
    "distributed-async-await",
    "faas",
    "serverless",
    "google-cloud",
    "google-cloud-functions"
  ],
  "scripts": {
    "build": "tsc",
    "check": "biome check --write .",
    "fmt": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "latest",
    "open": "^10.2.0",
    "@google-cloud/functions-framework": "^3.5.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@resonatehq/sdk": "^0.10.0"
  }
}
