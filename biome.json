{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": { "enabled": true, "indentStyle": "space" },
  "linter": {
    "enabled": true,
    "rules": {
      "style": { "noNonNullAssertion": "off" },
      "suspicious": {
        "noExplicitAny": "off",
        "useAwait": "error"
      },
      "complexity": { "useOptionalChain": "error" }
    }
  },
  "files": {
    "includes": ["**", "!dist"]
  }
}
